{
  "$comment": "Ruleset meta — read WITHOUT executing code (UI listing, engineApi check, quarantine). Keep in sync with src/index.ts.",
  "id": "com.illusions-lab.genji-vocab",
  "name": "Genji Vocabulary Check",
  "nameJa": "幻辞",
  "version": "0.3.1",
  "engineApi": 1,
  "license": "MIT",
  "maintainerEmail": "ruleset_maintainer@illusions.app",
  "rulesetPrefix": "genji-",
  "requires": [{ "kind": "dict", "dictId": "genji" }],
  "guidelines": [
    {
      "id": "genji-dict",
      "nameJa": "『幻辞.com』辞書チェック",
      "publisherJa": "illusions-lab",
      "year": null,
      "license": "Public",
      "descriptionJa": "幻辞（Genji）辞書に未収録の語を形態素解析で検出する。"
    }
  ],
  "rules": [
    {
      "ruleId": "genji-out-of-dict",
      "nameJa": "未知語の検出",
      "descriptionJa": "幻辞（Genji）辞書に未収録の名詞（固有名詞を含む）を検出します。誤字・誤変換・未知語の発見に役立ちます。動詞・形容詞は幻辞に一般語の収録が少なく誤検出が多いため既定では対象外です（オプション includeVerbsAdjectives で有効化可能）。記号・軽動詞・形式名詞・活用の派生形は型解析で除外します。",
      "guidelineId": "genji-dict",
      "level": "L2",
      "defaultConfig": {
        "enabled": true,
        "severity": "info",
        "options": {
          "includeProperNouns": true,
          "includeVerbsAdjectives": false,
          "minLength": 1,
          "filterSymbols": true,
          "filterLightVerbs": true,
          "filterFormalNouns": true,
          "filterDerivedConjugations": true
        }
      },
      "applicableModes": ["novel", "official", "blog", "academic", "sns"],
      "suggestsDictionaryEntry": true,
      "requires": [{ "kind": "dict", "dictId": "genji" }],
      "docs": {
        "positiveExample": "彼は図書館で本を読んだ。",
        "negativeExample": "彼は圕で本を讀んだ。",
        "sourceReference": "幻辞（Genji）辞書データベース"
      }
    }
  ]
}
